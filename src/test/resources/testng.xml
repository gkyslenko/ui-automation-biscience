<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Smoke" verbose="1" parallel="none">

    <listeners>
        <listener class-name="com.biscience.automation.listeners.ScreenshotListener"/>
    </listeners>

    <test name="Ad Intelligence – Brands Module" preserve-order="true">
        <classes>
            <class name="com.biscience.automation.smoke.brands.BrandsTest"/>
        </classes>
    </test>

    <test name="AI Chatbot – Ask anything" preserve-order="true">
        <classes>
            <class name="com.biscience.automation.smoke.chatbot.ChatbotTest"/>
        </classes>
    </test>

</suite>

